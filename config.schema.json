{
  "pluginAlias": "SofabatonPlatform",
  "pluginType": "platform",
  "singular": true,
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Name",
        "type": "string",
        "default": "Sofabaton",
        "description": "Display name for the TV accessory in Apple Home."
      },
      "nodeId": {
        "title": "Node ID",
        "type": "string",
        "description": "Your Sofabaton node ID. Find it in the Sofabaton app under Me → API Interface — copy the node_id value from any of the URLs shown."
      },
      "mainActivity": {
        "title": "Main Activity",
        "type": "string",
        "description": "Activity to launch when you tap the power button in Apple Home. Must match an activity name exactly."
      },
      "activities": {
        "title": "Activities",
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "List of activity names to expose as inputs in Apple Home. Names must match exactly as shown in the Sofabaton app API Interface screen."
      },
      "remoteOverrideCommandsList": {
        "title": "Remote Key Overrides",
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "key": {
              "title": "HomeKit Remote Key",
              "type": "string",
              "enum": [
                "ARROW_UP",
                "ARROW_DOWN",
                "ARROW_LEFT",
                "ARROW_RIGHT",
                "SELECT",
                "BACK",
                "EXIT",
                "PLAY_PAUSE",
                "INFORMATION",
                "REWIND",
                "FAST_FORWARD",
                "NEXT_TRACK",
                "PREVIOUS_TRACK"
              ]
            },
            "command": {
              "title": "Command",
              "type": "string"
            }
          },
          "required": ["key", "command"]
        }
      }
    },
    "required": ["nodeId", "activities"]
  },
  "form": [
    "name",
    "nodeId",
    "mainActivity",
    {
      "key": "activities",
      "type": "array",
      "title": "Activities",
      "items": [{ "key": "activities[]", "title": "Activity Name" }]
    },
    {
      "key": "remoteOverrideCommandsList",
      "type": "array",
      "title": "Remote Key Overrides",
      "items": [
        { "key": "remoteOverrideCommandsList[].key", "title": "Key" },
        { "key": "remoteOverrideCommandsList[].command", "title": "Command" }
      ]
    }
  ]
}
